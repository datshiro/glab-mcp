{
  "name": "glab-mcp",
  "version": "1.4.0",
  "description": "GitLab MCP server — create MRs, watch pipelines, ship code without leaving your AI session",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "glab-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "gitlab",
    "merge-request",
    "pipeline",
    "claude"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datshiro/glab-mcp.git"
  },
  "homepage": "https://github.com/datshiro/glab-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
